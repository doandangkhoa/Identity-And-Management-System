@startuml IAM_MFA_Class_Diagram

title IAM/MFA System - Class Diagram

top to bottom direction

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 70
hide circle

' ===== ENUMS =====

enum UserStatus {
  PENDING
  ACTIVE
  LOCKED
  INACTIVE
}


enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  MFA_ENABLED
  MFA_DISABLED
  PASSWORD_CHANGED
  USER_LOCKED
  USER_UNLOCKED
  USER_CREATED
  ROLE_ASSIGNED
  ROLE_REVOKED
  SESSION_REVOKED
  CLIENT_APP_REGISTERED
}

' ===== ENTITIES =====

class SecurityPolicy {
  - id: String
  - policyName: String
  - maxLoginAttempts: Integer
  - lockoutDurationMinutes: Integer
  - passwordMinLength: Integer
  - passwordRequireUppercase: Boolean
  - passwordRequireDigit: Boolean
  - passwordRequireSpecialChar: Boolean
  - passwordExpiryDays: Integer
  - passwordHistoryCount: Integer
  - sessionTimeoutMinutes: Integer
  - maxConcurrentSessions: Integer
  - mfaRequired: Boolean
  --
  + validate(): Boolean
  + enforce(user: User): void
  + isPasswordCompliant(password: String): Boolean
  + isLockoutRequired(failedAttempts: Integer): Boolean
}

class User {
  - id: String
  - username: String
  - email: String
  - passwordHash: String
  - failedLoginAttempts: Integer
  - status: UserStatus
  - lastLoginAt: DateTime
  - passwordChangedAt: DateTime
  - createdAt: DateTime
  - updatedAt: DateTime
  --
  + login(): Boolean
  + changePassword(oldPassword: String, newPassword: String): Boolean
  + lockAccount(): void
  + unlockAccount(): void
  + resetFailedAttempts(): void
  + getUserProfile(): User
}

class Role {
  - id: String
  - roleName: String
  - description: String
  - isActive: Boolean
  - createdAt: DateTime
  --
  + assignPermission(permission: Permission): void
  + revokePermission(permission: Permission): void
}

class Permission {
  - id: String
  - permissionName: String
  - resource: String
  - action: String
}


class PasswordHistory {
  - id: String
  - userId: String
  - passwordHash: String
  - createdAt: DateTime
  --
  + isPasswordReused(newPasswordHash: String): Boolean
}

class MfaProfile {
  - id: String
  - userId: String
  - secretKeyEncrypted: String
  - isVerified: Boolean
  - lastVerifiedAt: DateTime
  - createdAt: DateTime
  --
  + generateSecretKey(): String
  + verifyTotp(code: String): Boolean
  + enableMfa(): void
  + disableMfa(): void
}

class RecoveryCode {
  - id: String
  - mfaProfileId: String
  - codeHash: String
  - isUsed: Boolean
  - usedAt: DateTime
  - createdAt: DateTime
  --
  + generateRecoveryCode(): String
  + verify(plainCode: String): Boolean
}

class AuditLog {
  - id: String
  - userId: String
  - action: AuditAction
  - detail: String
  - ipAddress: String
  - userAgent: String
  - sessionId: String
  - timestamp: DateTime
  --
  + logEvent(): void
  + exportLog(): String
}

class UserSession {
  - id: String
  - userId: String
  - clientAppId: String
  - accessToken: String
  - refreshToken: String
  - ipAddress: String
  - deviceInfo: String
  - expiresAt: DateTime
  - refreshTokenExpiresAt: DateTime
  - isRevoked: Boolean
  - lastAccessedAt: DateTime
  - createdAt: DateTime
  --
  + createSession(): UserSession
  + refreshSession(): UserSession
  + revokeSession(): void
  + isSessionValid(): Boolean
}

class ClientApplication {
  - id: String
  - appName: String
  - clientSecretKey: String
  - redirectUri: String
  - allowedScopes: Set<String>
  - grantTypes: Set<String>
  - isActive: Boolean
  - createdAt: DateTime
  --
  + authenticateClient(clientSecret: String): Boolean
  + revokeClient(): void
}

' ===== RELATIONSHIPS =====

' SecurityPolicy enforces rules on User, Session, MFA, and ClientApplication
SecurityPolicy ..> User : <<enforces>>
SecurityPolicy ..> UserSession : <<enforces>>
SecurityPolicy ..> MfaProfile : <<enforces>>
SecurityPolicy ..> ClientApplication : <<enforces>>

' Enum dependencies
User ..> UserStatus
AuditLog ..> AuditAction

' RBAC (Many-to-Many)
User "0..*" -- "0..*" Role
Role "0..*" -- "0..*" Permission

' Password History (User has many PasswordHistory records)
User "1" *-- "0..*" PasswordHistory

' MFA Lifecycle (User owns one optional MfaProfile — aggregation to allow history retention)
User "1" o-- "0..1" MfaProfile

' MfaProfile owns many RecoveryCodes (composition — codes meaningless without profile)
MfaProfile "1" *-- "0..*" RecoveryCode

' Audit (User has many AuditLogs — association, logs persist independently)
User "1" -- "0..*" AuditLog

' Session Management (User has many Sessions — aggregation, sessions can be revoked independently)
User "1" o-- "0..*" UserSession

' UserSession belongs to ClientApplication (optional if direct login exists)
UserSession "0..*" -- "0..1" ClientApplication

@enduml
