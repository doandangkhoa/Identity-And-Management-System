@startuml IAM_MFA_Class_Diagram

title IAM/MFA System - Class Diagram

top to bottom direction

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 70
hide circle

' ===== ENUMS =====

enum UserStatus {
  ACTIVE
  LOCKED
  DEACTIVATED
}

' ===== ENTITIES =====

class User {
  - userId: Long
  - username: String
  - email: String
  - passwordHash: String
  - isMFAEnabled: Boolean
  - status: UserStatus
  - createdAt: DateTime
  --
  + login(username: String, password: String): Boolean
  + logout(): void
  + changePassword(oldPassword: String, newPassword: String): Boolean
  + validatePassword(password: String): Boolean
}

class Admin {
  - adminId: Long
  - username: String
  - role: String
  --
  + manageUser(userId: Long): void
  + lockUser(userId: Long): void
  + unlockUser(userId: Long): void
  + assignRole(userId: Long, role: String): void
}

class Role {
  - roleId: Long
  - roleName: String
  --
  + assignPermission(permission: Permission): void
}

class Permission {
  - permissionId: Long
  - permissionName: String
}

class Session {
  - sessionId: String
  - token: String
  - deviceInfo: String
  - ipAddress: String
  - location: String
  - createdAt: DateTime
  - expiresAt: DateTime
  - isActive: Boolean
  --
  + validateToken(token: String): Boolean
  + revoke(): void
  + refreshToken(): String
}

class MFAConfig {
  - configId: Long
  - secretKey: String
  - createdAt: DateTime
  - verified: Boolean
  --
  + generateSecretKey(): String
  + generateQRCode(): Image
  + verifyTOTP(code: String): Boolean
}

class RecoveryCode {
  - codeId: Long
  - codeHash: String
  - isUsed: Boolean
  - usedAt: DateTime
  --
  + verifyCode(input: String): Boolean
  + markAsUsed(): void
}

class AuditLog {
  - logId: Long
  - action: String
  - userId: Long
  - adminId: Long
  - timestamp: DateTime
  - ipAddress: String
  - details: String
  --
  + logAction(action: String, details: String): void
  + queryLogs(filters: Map): List<AuditLog>
}

' ===== SERVICES =====

class ClientApplication {
  - appId: String
  - appName: String
  - apiKey: String
  - callbackUrl: String
  --
  + requestUserProfile(token: String): User
  + validateAccessToken(token: String): Boolean
}

class APIGateway {
  - gatewayId: String
  --
  + validateToken(token: String): Boolean
  + routeRequest(request: Request): Response
  + authenticate(request: Request): User
}

class TokenService {
  - issuer: String
  - signingKeyId: String
  --
  + verifySignature(token: String): Boolean
  + checkExpiration(token: String): Boolean
  + extractClaims(token: String): Claims
}

class TOTPService {
  - timeStepSeconds: Integer
  - allowedDriftSteps: Integer
  --
  + generateCode(secret: String, time: Long): String
  + verifyCode(secret: String, code: String): Boolean
  + checkMFAStatus(userId: Long): Boolean
}

' ===== RELATIONSHIPS =====

' Enum dependency
User ..> UserStatus

' Inheritance: Admin extends User
Admin --|> User

' RBAC (Many-to-Many)
User "0..*" -- "0..*" Role
Role "0..*" -- "0..*" Permission

' Authentication & Session Management
User "1" *-- "0..*" Session

' MFA Lifecycle
User "1" *-- "0..1" MFAConfig
MFAConfig "1" *-- "0..*" RecoveryCode
MFAConfig ..> TOTPService

' Audit
User "1" -- "0..*" AuditLog
Admin ..> AuditLog

' API Communication
ClientApplication ..> APIGateway
APIGateway ..> TokenService
APIGateway ..> TOTPService

@enduml
